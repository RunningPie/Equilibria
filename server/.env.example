# === DB variables ===
DB_USER=equilibria_user
DB_PASSWORD=equilibria_password
DB_NAME=equilibria_db
DB_HOST=db
DB_PORT=5432

DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# === Application Variables ===
ENVIRONMENT=development
PYTHONPATH=/app

# === Security Variables ===
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ALGORITHM=HS256
SANDBOX_DB_ROLE=sandbox_executor
CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173", "http://localhost:3000"]
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === Logging Variables ===
LOG_DIR=/app/logs
SYSLOG_DIR=/app/logs/syslog
ASSLOG_DIR=/app/logs/asslog
LOG_LEVEL=INFO